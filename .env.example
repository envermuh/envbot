# Copy to .env and add your secret key (never commit .env to git).
# Get a key: https://platform.openai.com/api-keys



# Supabase (persistent memory)
# Create a project on Supabase, then set:
# - Project URL (Settings → API): SUPABASE_URL
# - Service role key (Settings → API): SUPABASE_SECRET_KEY  (server-only!)
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
TAVILY_API_KEY=
OPENAI_MODEL=

# Tavily web search (for web-grounded answers)
# Get a key from Tavily, then set it here:


# Optional: default is gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: port (default 3000)
# PORT=3000
